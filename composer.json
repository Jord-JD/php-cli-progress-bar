{
  "name": "jord-jd/php-cli-progress-bar",
  "description": "Progress bar for command line PHP scripts",
  "type": "library",
  "license": "LGPL-3.0-only",
  "authors": [
    {
      "name": "Jordan Hall",
      "email": "jordan@hall05.co.uk"
    }
  ],
  "require": {
    "php": ">=5.6",
    "khill/php-duration": "^1.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^5.7||^9.6"
  },
  "autoload": {
    "psr-4": {
      "JordJD\\CliProgressBar\\": "./src/"
    }
  },
  "replace": {
    "divineomega/php-cli-progress-bar": "self.version"
  },
  "extra": {
    "branch-alias": {
      "dev-master": "4.0-dev"
    }
  }
}
